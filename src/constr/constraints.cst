// ============== CONFIGURACIÓN DE PINES ORDENADA (VERSIÓN FINAL) ==============
// Basado en el esquemático oficial y la prueba de reset exitosa
// Display movido al banco IOB (3.3V) para evitar transistores

// --- PINES FIJOS DE LA PLACA ---
IO_LOC "clk_27mhz" 52; // Reloj de 27MHz

// --- DISPLAY: BANCO IOB 3.3V (12 PINES) ---
IO_LOC "segmentos_out[0]" 25; // Segmento a (IOB8A)
IO_LOC "segmentos_out[1]" 26; // Segmento b (IOB8B)
IO_LOC "segmentos_out[2]" 27; // Segmento c (IOB11A)
IO_LOC "segmentos_out[3]" 28; // Segmento d (IOB11B)
IO_LOC "segmentos_out[4]" 29; // Segmento e (IOB13A)
IO_LOC "segmentos_out[5]" 30; // Segmento f (IOB13B)
IO_LOC "segmentos_out[6]" 33; // Segmento g (IOB23A)
IO_LOC "segmentos_out[7]" 34; // Punto Decimal (IOB23B)
IO_LOC "anodos_out[0]"    35; // Control Dígito 1 (IOB29A)
IO_LOC "anodos_out[1]"    42; // Control Dígito 2 (IOB41B)
IO_LOC "anodos_out[2]"    55; // Control Dígito 3 (IOR14B)
IO_LOC "anodos_out[3]"    56; // Control Dígito 4 (IOR14A)

// --- GRUPO INFERIOR: E/S DEL TECLADO Y RESET (9 PINES) ---
// Columnas (Salidas)
IO_LOC "keypad_cols[0]" 38; // Columna 1
IO_LOC "keypad_cols[1]" 37; // Columna 2
IO_LOC "keypad_cols[2]" 36; // Columna 3
IO_LOC "keypad_cols[3]" 39; // Columna 4

// Filas (Entradas)
IO_LOC "keypad_rows[0]" 40; // Fila 1
IO_LOC "keypad_rows[1]" 41; // Fila 2
IO_LOC "keypad_rows[2]" 51; // Fila 3
IO_LOC "keypad_rows[3]" 53; // Fila 4

// Pin de Reset (Entrada)
IO_LOC "reset_n"   54; // RESET OFICIAL
IO_PULL "reset_n" "PULL_UP"; // Habilita Pull-up interno